Host powerslabs
    HostName ssh.powerslabs.org
    User joshua

    # X11 Forwarding
    ForwardX11 yes
    ForwardX11Trusted yes        # 'yes' if apps complain or need full access

    # Use your ed25519 key explicitly
    IdentityFile ~/.ssh/id_ed25519
    IdentitiesOnly yes          # Don't try other keys if this one fails

    # SSH agent forwarding (lets remote host use your local keys)
    ForwardAgent yes

    # Connection stability
    ServerAliveInterval 60      # Send keepalive every 60s
    ServerAliveCountMax 3       # Disconnect after 3 missed responses

    # Speed / convenience
    Compression yes             # Helpful for X11/slow links
    ControlMaster auto          # Reuse connections (faster subsequent sessions)
    ControlPath ~/.ssh/cm-%r@%h:%p
    ControlPersist 10m          # Keep master alive 10min after last session
