# --- Fonts ---
window-title-font-family = Victor Mono
font-family = Victor Mono
font-family-bold = Victor Mono
font-family-italic = Victor Mono
font-family-bold-italic = Victor Mono
font-style = Regular
font-style-bold = Bold
font-style-italic = Italic
font-style-bold-italic = Bold Italic
font-feature = calt
font-size = 14
font-thicken = true

# --- Theme ---
# Automatically picks light/dark variant based on system theme.
# "auto" here means Ghostty will detect system dark/light mode.
theme = dark:Selenized Dark,light:Selenized Light
window-theme = system

# --- Cursor ---
cursor-style = bar
cursor-style-blink = true
cursor-click-to-move = true

# --- Mouse ---
mouse-hide-while-typing = true
mouse-shift-capture = false

# --- Shell ---
shell-integration = detect
shell-integration-features = true

# --- Window / Behavior ---
working-directory = home
quit-after-last-window-closed = true
